{{!< default}}

<main>
    <div class="container">
        {{#author}}
            <header class="author-header">
                <h1 class="author-header-name">{{name}}</h1>
                {{#if bio}}
                    <p class="author-header-bio">{{bio}}</p>
                {{/if}}
            </header>
        {{/author}}

        <div class="post-feed">
            {{#foreach posts}}
                {{> post-card}}
            {{/foreach}}

            {{#if pagination.pages}}
                {{#if (gt pagination.pages 1)}}
                    <nav class="pagination">
                        {{#if pagination.prev}}
                            <a href="{{pagination.prev}}">← Newer posts</a>
                        {{else}}
                            <span></span>
                        {{/if}}
                        <span class="page-number">Page {{pagination.page}} of {{pagination.pages}}</span>
                        {{#if pagination.next}}
                            <a href="{{pagination.next}}">Older posts →</a>
                        {{else}}
                            <span></span>
                        {{/if}}
                    </nav>
                {{/if}}
            {{/if}}
        </div>
    </div>
</main>
