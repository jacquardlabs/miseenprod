{{!< default}}

<main class="post-feed">
    <div class="container">
        {{#foreach posts}}
            {{> post-card}}
        {{/foreach}}

        {{#if pagination.next}}
            <nav class="pagination">
                {{#if pagination.prev}}
                    <a href="{{pagination.prev}}">← Newer posts</a>
                {{else}}
                    <span></span>
                {{/if}}
                <span class="page-number">Page {{pagination.page}} of {{pagination.pages}}</span>
                <a href="{{pagination.next}}">Older posts →</a>
            </nav>
        {{else if pagination.prev}}
            <nav class="pagination">
                <a href="{{pagination.prev}}">← Newer posts</a>
                <span class="page-number">Page {{pagination.page}} of {{pagination.pages}}</span>
                <span></span>
            </nav>
        {{/if}}
    </div>
</main>
